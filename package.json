{
  "name": "hl-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Local deterministic document processing for HL review workflows.",
  "productName": "HL Intelligence",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.node.json && node scripts/copy-static.mjs && vite build",
    "test": "vitest run",
    "smoke": "npm run build && npm run test && npm run skill:build",
    "skill:build": "node scripts/build-skill.mjs",
    "assets:windows": "node scripts/generate-windows-assets.mjs",
    "package:win": "node scripts/package-win.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.houlihanlokey.hl-intelligence",
    "productName": "HL Intelligence",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "public/**",
      "skills/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "skills",
        "to": "skills"
      },
      {
        "from": "public/brand",
        "to": "brand"
      },
      {
        "from": "build/hl-intelligence.ico",
        "to": "hl-intelligence.ico"
      },
      {
        "from": "build/hl-intelligence-icon-256.png",
        "to": "hl-intelligence-icon-256.png"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "build/hl-intelligence.ico"
    }
  }
}

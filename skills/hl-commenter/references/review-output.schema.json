{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hl-intelligence.local/schemas/review-output.schema.json",
  "title": "HL Commenter result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "source_sha256", "findings"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "request_id": { "type": "string", "minLength": 8 },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "findings": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "anchor", "comment_body"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 40 },
          "anchor": {
            "oneOf": [
              { "$ref": "#/$defs/pdf_block_anchor" },
              { "$ref": "#/$defs/pdf_page_anchor" },
              { "$ref": "#/$defs/docx_paragraph_anchor" },
              { "$ref": "#/$defs/docx_table_cell_anchor" },
              { "$ref": "#/$defs/xlsx_cell_anchor" },
              { "$ref": "#/$defs/xlsx_range_anchor" },
              { "$ref": "#/$defs/pptx_shape_anchor" },
              { "$ref": "#/$defs/pptx_slide_anchor" }
            ]
          },
          "evidence": { "type": "string", "maxLength": 2000 },
          "value": {
            "anyOf": [
              { "type": "string", "maxLength": 240 },
              { "type": "null" }
            ]
          },
          "comment_body": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "suggested_replacement": {
            "anyOf": [
              { "type": "string", "maxLength": 2000 },
              { "type": "null" }
            ]
          },
          "category": {
            "anyOf": [
              { "type": "string", "maxLength": 80 },
              { "type": "null" }
            ]
          },
          "severity": {
            "anyOf": [
              { "enum": ["low", "medium", "high"] },
              { "type": "null" }
            ]
          },
          "confidence": {
            "anyOf": [
              { "type": "number", "minimum": 0, "maximum": 1 },
              { "type": "null" }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "pdf_block_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "page", "block_id"],
      "properties": {
        "kind": { "const": "pdf_block" },
        "page": { "type": "integer", "minimum": 1 },
        "block_id": { "type": "string", "minLength": 1 }
      }
    },
    "pdf_page_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "page"],
      "properties": {
        "kind": { "const": "pdf_page" },
        "page": { "type": "integer", "minimum": 1 }
      }
    },
    "docx_paragraph_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "paragraph_id"],
      "properties": {
        "kind": { "const": "docx_paragraph" },
        "paragraph_id": { "type": "string", "minLength": 1 },
        "page": { "type": "integer", "minimum": 1 }
      }
    },
    "docx_table_cell_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "table_id", "row", "column", "cell_id"],
      "properties": {
        "kind": { "const": "docx_table_cell" },
        "table_id": { "type": "string", "minLength": 1 },
        "row": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 },
        "cell_id": { "type": "string", "minLength": 1 },
        "page": { "type": "integer", "minimum": 1 }
      }
    },
    "xlsx_cell_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sheet", "cell"],
      "properties": {
        "kind": { "const": "xlsx_cell" },
        "sheet": { "type": "string", "minLength": 1 },
        "cell": { "type": "string", "pattern": "^\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*$" }
      }
    },
    "xlsx_range_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sheet", "range"],
      "properties": {
        "kind": { "const": "xlsx_range" },
        "sheet": { "type": "string", "minLength": 1 },
        "range": { "type": "string", "pattern": "^\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*(?::\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*)?$" }
      }
    },
    "pptx_shape_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "slide", "slide_id", "shape_id"],
      "properties": {
        "kind": { "const": "pptx_shape" },
        "slide": { "type": "integer", "minimum": 1 },
        "slide_id": { "type": "integer", "minimum": 1 },
        "shape_id": { "type": "string", "minLength": 1 }
      }
    },
    "pptx_slide_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "slide", "slide_id"],
      "properties": {
        "kind": { "const": "pptx_slide" },
        "slide": { "type": "integer", "minimum": 1 },
        "slide_id": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
